# INTUS Platform frontend — copy to .env and fill in
# Without these the app runs in "modo local" (no login, browser-only storage).
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Backend API base. Leave empty for local dev (Vite proxies /api → :3002).
# Set to the Railway URL for production builds.
VITE_API_BASE=
