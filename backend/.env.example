# Claude API
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6
USE_CLAUDE_API=true
MOCK_API=false

# Agent token limits
MAX_OUTPUT_TOKENS=9000
AGENT2_MAX_OUTPUT_TOKENS=4500
AGENT3_MAX_OUTPUT_TOKENS=12500

# Web search
ENABLE_WEB_SEARCH=true
WEB_SEARCH_MAX_USES=6
AGENT2_WEB_SEARCH_MAX_USES=3

# Dashboard — path to the source dashboard HTML file (relative to backend/)
DASHBOARD_FILE_PATH=./dashboard/etra_capex_v1_6_0_5_iro_5.html

# Dashboard output directory — where generated dashboard copies are saved
# Note: Railway has an ephemeral filesystem — files are lost on restart.
DASHBOARD_OUTPUT_DIR=./data/dashboard-outputs

# Server port — Railway sets this automatically. Do not set manually on Railway.
PORT=3001

SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
